# Local (default if unset): SQLite file nutrition.db
# DATABASE_URL=sqlite:///nutrition.db

# Docker Compose / AWS RDS example (Postgres):
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/nutrition

# Comma-separated frontends, or * for demo
# CORS_ORIGINS=http://localhost:3000,https://app.example.com

# Run alembic upgrade head when the API process starts (useful on App Runner)
# RUN_MIGRATIONS_ON_STARTUP=true
